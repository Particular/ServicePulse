{
  packageRules: [
    {
      matchDatasources: [
        'npm',
      ],
      minimumReleaseAge: '4 days',
    },
    {
      matchDatasources: [
        'npm',
      ],
      matchUpdateTypes: [
        'patch',
      ],
      groupName: 'npm patch updates',
      groupSlug: 'npm-patch-updates',
    },
    {
      matchDatasources: [
        'npm',
      ],
      matchPackageNames: [
        'vitest',
        '@vitest/coverage-v8',
      ],
      groupName: 'vitest',
      groupSlug: 'vitest-group',
    },
    {
      matchDatasources: [
        'npm',
      ],
      matchPackageNames: [
        'vite',
        '@vitejs/plugin-vue',
        'vite-plugin-checker',
        'vite-plugin-vue-devtools',
      ],
      groupName: 'vite',
      groupSlug: 'vite-group',
    },
    {
      matchDatasources: [
        'npm',
      ],
      matchPackageNames: [
        'vue',
        'vue-router',
        'pinia',
        '@pinia/testing',
        'vue-tsc',
        '@vue/tsconfig',
      ],
      groupName: 'vue',
      groupSlug: 'vue-group',
    },
    {
      matchDatasources: [
        'npm',
      ],
      matchPackageNames: [
        'codemirror',
        'vue-codemirror6',
        '/^@codemirror//',
      ],
      groupName: 'codemirror',
      groupSlug: 'codemirror-group',
    },
    {
      matchDatasources: [
        'npm',
      ],
      groupName: 'fontawesome',
      groupSlug: 'fontawesome-group',
      matchPackageNames: [
        '/^@fortawesome//',
      ],
    },
    {
      matchDatasources: [
        'npm',
      ],
      groupName: 'testing-library',
      groupSlug: 'testing-library-group',
      matchPackageNames: [
        '/^@testing-library//',
      ],
    },
    {
      matchDatasources: [
        'npm',
      ],
      matchPackageNames: [
        'eslint',
        '@eslint/js',
        'eslint-plugin-vue',
        'typescript-eslint',
        'eslint-config-prettier',
        'eslint-plugin-prettier',
      ],
      groupName: 'eslint',
      groupSlug: 'eslint-group',
    },
    {
      matchDatasources: [
        'npm',
      ],
      groupName: 'vue-flow',
      groupSlug: 'vue-flow-group',
      matchPackageNames: [
        '/^@vue-flow//',
      ],
    },
    {
      matchDatasources: [
        'npm',
      ],
      matchPackageNames: [
        'msw',
      ],
      groupName: 'msw',
      groupSlug: 'msw-group',
      prBodyNotes: [
        '> [!WARNING]\n> **Do not auto-merge or merge via this PR directly.** `msw` runs a post-install script that regenerates `mockServiceWorker.js` with the new version number. After merging, you must manually run `npx msw init <PUBLIC_DIR>` to update this generated file, then commit the result.',
      ],
    },
  ],
}
